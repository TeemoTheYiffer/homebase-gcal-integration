# Homebase login (single account; sees the whole team grid)
HOMEBASE_EMAIL=you@example.com
HOMEBASE_PASSWORD=replace-me

# Path to the employee -> calendar map
EMPLOYEES_CONFIG_PATH=employees.toml

# Google OAuth (Desktop app)
GCAL_CREDENTIALS_PATH=.secrets/credentials.json
GCAL_TOKEN_PATH=.secrets/token.json

# Sync behavior
SYNC_TIMEZONE=America/Los_Angeles
LOG_LEVEL=INFO
