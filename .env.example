# Homebase login (single account; sees the whole team grid)
HOMEBASE_EMAIL=you@example.com
HOMEBASE_PASSWORD=replace-me

# Path to the employee -> calendar map
EMPLOYEES_CONFIG_PATH=employees.toml

# Sync behavior
SYNC_TIMEZONE=America/Los_Angeles
LOG_LEVEL=INFO

# Google Calendar auth: uses Application Default Credentials.
#   Local dev:  run `gcloud auth application-default login`
#   Cloud Run:  uses the runtime SA from the metadata server (no config needed)
# Each calendar in employees.toml must be shared with the principal you're
# authenticated as ("Make changes to events" rights).
